ded-4 overflow-hidden\">\n                        <h2 class=\"accordion-header\">\n                            <button class=\"accordion-button collapsed fw-bold\" type=\"button\" data-bs-toggle=\"collapse\"\n                                data-bs-target=\"#faq2\">\n                                Ki diferans ki genyen ak asirans invalidite a?\n                            <\/button>\n                        <\/h2>\n                        <div id=\"faq2\" class=\"accordion-collapse collapse\" data-bs-parent=\"#faqMG\">\n                            <div class=\"accordion-body text-muted\">Asirans maladi grav la peye yon s\u00e8l montan kou yo f\u00e8 dyagnostik la, pandan asirans invalidite a ranplase k\u00f2b ou te konn f\u00e8 chak mwa a. Tou de mache ansanm.<\/div>\n                        <\/div>\n                    <\/div>\n                                    <\/div>\n            <\/div>\n        <\/div>\n    <\/div>\n<\/section>\n\n\n<div class=\"container py-4 border-top\">\n    <small class=\"text-muted\">\n        <strong>Sous ki verifye:<\/strong>\n        <ul class=\"list-inline mt-2\">\n                        <li class=\"list-inline-item\">\u2022 Estatistik Kanada (Statistique Canada)<\/li>\n                        <li class=\"list-inline-item\">\u2022 Sosyete Kanadyen pou Kans\u00e8 (Soci\u00e9t\u00e9 canadienne du cancer)<\/li>\n                        <li class=\"list-inline-item\">\u2022 Otorite Mache Finansye yo (AMF)<\/li>\n                    <\/ul>\n    <\/small>\n<\/div>\n\n<footer class=\"footer-premium\">\r\n    <div class=\"container\">\r\n        <div class=\"row g-4\">\r\n\r\n            \r\n            <div class=\"col-lg-4 col-md-6 mb-4 mb-lg-0\">\r\n                <a href=\"https:\/\/vipgpi.net\/ht\/home\" class=\"d-inline-block mb-4\">\r\n                    <img src=\"https:\/\/vipgpi.net\/assets\/img\/footer\/VIP_Logo_Gold_Gradient10.png\" alt=\"VIP GPI\"\r\n                        style=\"height: 90px;\">\r\n                <\/a>\