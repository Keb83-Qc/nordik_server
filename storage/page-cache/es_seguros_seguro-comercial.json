abf|conseiller|logout)\/.test(href)) return;\n\n        clearTimeout(timer);\n        timer = setTimeout(() => prefetch(a.href), 65);\n    }, { passive: true });\n\n    document.addEventListener('mouseout', function () {\n        clearTimeout(timer);\n    }, { passive: true });\n})();\n<\/script>\n\n\n<\/body>\n\n<\/html>","created_at":1773828162}