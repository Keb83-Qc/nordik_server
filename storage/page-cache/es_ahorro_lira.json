{"headers":{"Content-Type":"text\/html; charset=utf-8"},"html":"<!DOCTYPE html>\r\n<html lang=\"es\">\r\n\r\n<head>\r\n    <meta charset=\"UTF-8\">\r\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n    <meta name=\"csrf-token\" content=\"gpiguHrRs8u5OiJ0XK7MuJaf53GFFmGb16iQOseD\">\r\n\r\n    <link rel=\"icon\" type=\"image\/x-icon\" href=\"https:\/\/vipgpi.net\/assets\/img\/header\/favicon.ico\">\r\n\r\n    \r\n    <link rel=\"preconnect\" href=\"https:\/\/cdn.jsdelivr.net\" crossorigin>\r\n    <link rel=\"preconnect\" href=\"https:\/\/cdnjs.cloudflare.com\" crossorigin>\r\n\r\n    \r\n    <link rel=\"stylesheet\" href=\"https:\/\/vipgpi.net\/assets\/css\/fonts.css\">\r\n\r\n    \r\n    <link href=\"https:\/\/cdn.jsdelivr.net\/npm\/bootstrap@5.3.0\/dist\/css\/bootstrap.min.css\" rel=\"stylesheet\" crossorigin=\"anonymous\">\r\n    <link rel=\"stylesheet\" href=\"https:\/\/cdnjs.cloudflare.com\/ajax\/libs\/font-awesome\/6.4.0\/css\/all.min.css\" crossorigin=\"anonymous\">\r\n\r\n    \r\n        <link rel=\"stylesheet\" href=\"https:\/\/vipgpi.net\/assets\/css\/vip.css?v=1773005847\">\r\n\r\n    \r\n    \r\n    \r\n    \r\n\r\n\r\n    \r\n    <script type=\"application\/ld+json\">\r\n        {\r\n            \"@context\": \"https:\/\/schema.org\",\r\n            \"@type\": \"FinancialService\",\r\n            \"name\": \"VIP GPI Services Financiers\",\r\n            \"image\": \"https:\/\/vipgpi.net\/assets\/img\/header\/VIP_Logo_Gold_Gradient10.png\",\r\n            \"telephone\": \"+14388382630\",\r\n            \"email\": \"admin@vipgpi.ca\",\r\n            \"address\": {\r\n                \"@type\": \"PostalAddress\",\r\n                \"streetAddress\": \"2990 av. Pierre-P\u00e9ladeau, suite 400\",\r\n                \"addressLocality\": \"Laval\",\r\n                \"addressRegion\": \"QC\",\r\n                \"postalCode\": \"H7T 3B3\",\r\n                \"addressCountry\": \"CA\"\r\n            },\r\n            \"url\":