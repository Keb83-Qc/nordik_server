ntact\" class=\"btn vip-btn-gold rounded-pill px-4 py-2 w-100 w-xl-auto\">\n                        Consulta gratuita\n                    <\/a>\n                <\/li>\n\n                <!-- Mobile: lien Services simple -->\n                <li class=\"nav-item d-xl-none\">\n                    <a class=\"nav-link\" href=\"\/es\/services\">Servicios<\/a>\n                <\/li>\n\n            <\/ul>\n        <\/div>\n    <\/div>\n<\/nav>\r\n    \r\n    \n\n<section class=\"section-padding bg-white\">\n    <div class=\"container\">\n        <div class=\"row align-items-center\">\n            <div class=\"col-lg-7\">\n                <h2 class=\"fw-bold mb-4 text-primary\">\u00bfQu\u00e9 es el Seguro de enfermedades graves en Quebec?<\/h2>\n                <p class=\"lead text-muted\">El seguro de enfermedades graves es una protecci\u00f3n financiera que paga una cantidad global libre de impuestos cuando un asegurado recibe el diagn\u00f3stico de una enfermedad grave cubierta por su contrato. Esta cantidad se puede utilizar libremente, sin justificaci\u00f3n, para hacer frente a las consecuencias financieras relacionadas con la enfermedad.<\/p>\n                <h4 class=\"fw-bold mt-5 mb-3\">Enfermedades cubiertas<\/h4>\n                <p>Dependiendo de la compa\u00f1\u00eda de seguros, una p\u00f3liza puede cubrir entre 4 y 30 enfermedades graves, incluyendo:<\/p>\n                <div class=\"row\">\n                                        <div class=\"col-md-6 mb-2\">\n                        <div class=\"d-flex align-items-center\">\n                            <i class=\"fas fa-check text-warning me-2\"><\/i>\n                            <span>El c\u00e1ncer<\/span>\n                        <\/div>\n                    <\/div>\n                                        <div class=\"col-md-6 mb-2\">\n                        <div class=\"d-flex align-items-center\">\n                            <i class=\"fas fa-check text-warning me-2\"><\/i>\n                            <span>El accidente cerebrovascular (ACV)<\/span>\n                        <\/div>\n                    <\/div>\n                                        <div class=\"col-md-6 mb-2\">\n                        <div class=\"d-flex align-items-center\">\n                            <i class=\"fas fa-check text-warning me-2\"><\/i>\n                            <span>El infarto de miocardio (ataque al coraz\u00f3n)<\/span>\n                        <\/div>\n                    <\/div>\n                                        <div class=\"col-md-6 mb-2\">\n                        <div class=\"d-flex align-items-center\">\n                            <i class=\"fas fa-check text-warning me-2\"><\/i>\n                            <span>La esclerosis m\u00faltiple<\/span>\n                        <\/div>\n                    <\/div>\n                                        <div class=\"col-md-6 mb-2\">\n                        <div class=\"d-flex align-items-center\">\n                            <i class=\"fas fa-check text-warning me-2\"><\/i>\n                            <span>Otras afecciones mayores<\/span>\n                        <\/div>\n                    <\/div>\n                                    <\/div>\n            <\/div>\n            <div class=\"col-lg-5 text-center mt-4 mt-lg-0\">\n                <img src=\"https:\/\/vipgpi.net\/assets\/img\/assuranceMaladieGrave\/A-cote-texte-Maladies-Graves.jpg\" class=\"img-fluid rounded-4 shadow\"\n                    alt=\"Maladies Graves\">\n            <\/div>\n        <\/div>\n    <\/div>\n<\/section>\n\n\n<section class=\"section-padding bg-light\">\n    <div class=\"container\">\n        <div class=\"row g-5 align-items-center flex-lg-row-reverse\">\n            <div class=\"col-lg-6\">\n                <h2 class=\"fw-bold mb-4\">Seguro de enfermedades graves y RAMQ: \u00bfcu\u00e1l es la diferencia?<\/h2>\n                <p>En Quebec, la RAMQ cubre los cuidados m\u00e9dicos esenciales (consultas, hospitalizaci\u00f3n, actos m\u00e9dicos).<\/p>\n                <div class=\"p-4 bg-white rounded-4 shadow-sm border-start border-4 border-danger\">\n                    <h5 class=\"fw-bold text-danger mb-3\">Sin embargo, la RAMQ no cubre:<\/h5>\n                    <ul class=\"list-unstyled mb-0\">\n                                                <li class=\"mb-2\"><i class=\"fas fa-times-circle text-danger me-2\"><\/i> La p\u00e9rdida de ingresos<\/li>\n                                                <li class=\"mb-2\"><i class=\"fas fa-times-circle text-danger me-2\"><\/i> Los medicamentos no asegurados<\/li>\n                                                <li class=\"mb-2\"><i class=\"fas fa-times-circle text-danger me-2\"><\/i> Los tratamientos privados o acelerados<\/li>\n                                                <li class=\"mb-2\"><i class=\"fas fa-times-circle text-danger me-2\"><\/i> Los cuidados a domicilio<\/li>\n                                                <li class=\"mb-2\"><i class=\"fas fa-times-circle text-danger me-2\"><\/i> Los desplazamientos, adaptaciones del hogar o gastos personales<\/li>\n                                            <\/ul>\n                <\/div>\n                <p class=\"mt-4 fst-italic text-muted\">El seguro de enfermedades graves complementa a la RAMQ, protegiendo la estabilidad financiera del asegurado y de su familia ante un diagn\u00f3stico mayor.<\/p>\n            <\/div>\n            <div class=\"col-lg-6\">\n                <img src=\"https:\/\/vipgpi.net\/assets\/img\/assuranceMaladieGrave\/AdobeStock_727436851.jpg\" class=\"img-fluid rounded-4 shadow\"\n                    alt=\"RAMQ vs Private\">\n            <\/div>\n        <\/div>\n    <\/div>\n<\/section>\n\n\n<section class=\"section-padding bg-white\">\n    <div class=\"container\">\n        <h2 class=\"text-center fw-bold mb-2\">Las repercusiones financieras reales de una enfermedad grave<\/h2>\n        <p class=\"text-center text-muted mb-5\">El diagn\u00f3stico de una enfermedad grave genera un estr\u00e9s financiero considerable que puede extenderse por a\u00f1os. Aqu\u00ed est\u00e1n las principales repercusiones:<\/p>\n        <div class=\"row g-4\">\n            <div class=\"col-md-6 col-lg-3\">\n                <div class=\"card h-100 border-0 bg-light p-4 rounded-4 shadow-sm\">\n                    <h5 class=\"fw-bold text-primary mb-3\">1. P\u00e9rdida de ingresos<\/h5>\n                    <p class=\"small text-muted mb-0\">La p\u00e9rdida de ingresos promedio es de $20,000 por ausentarse del trabajo debido a la enfermedad o los tratamientos. Los cuidadores tambi\u00e9n pierden en promedio el 25 % de sus ingresos.<\/p>\n                <\/div>\n            <\/div>\n            <div class=\"col-md-6 col-lg-3\">\n                <div class=\"card h-100 border-0 bg-light p-4 rounded-4 shadow-sm\">\n                    <h5 class=\"fw-bold text-primary mb-3\">2. Costos directos de por vida<\/h5>\n                    <p class=\"small text-muted mb-0\">El costo total de un c\u00e1ncer para el paciente promedio en Canad\u00e1 se estima en casi $33,000. En 2024, los costos asumidos por los pacientes y sus seres queridos se estiman en 5,200 millones de d\u00f3lares.<\/p>\n                <\/div>\n            <\/div>\n            <div class=\"col-md-6 col-lg-3\">\n                <div class=\"card h-100 border-0 bg-light p-4 rounded-4 shadow-sm\">\n                    <h5 class=\"fw-bold text-primary mb-3\">3. Tratamientos y medicamentos<\/h5>\n                    <p class=\"small text-muted mb-0\">El precio promedio de una serie de tratamientos es de $65,000 para los nuevos medicamentos. Incluso estando asegurado, podr\u00eda tener que pagar hasta el 20 % de los gastos.<\/p>\n                <\/div>\n            <\/div>\n            <div class=\"col-md-6 col-lg-3\">\n                <div class=\"card h-100 border-0 bg-light p-4 rounded-4 shadow-sm\">\n                    <h5 class=\"fw-bold text-primary mb-3\">4. Gastos indirectos<\/h5>\n                    <p class=\"small text-muted mb-0\">Gastos que se acumulan r\u00e1pidamente: desplazamientos, estacionamiento, comidas en el hospital, alojamiento, cuidado de ni\u00f1os, limpieza del hogar, pr\u00f3tesis y suministros m\u00e9dicos.<\/p>\n                <\/div>\n            <\/div>\n        <\/div>\n        <div class=\"mt-5 p-4 bg-warning bg-opacity-10 border-start border-4 border-warning rounded text-center\">\n            <p class=\"mb-0 fw-bold text-dark\"><i class=\"fas fa-exclamation-triangle me-2\"><\/i>\n                Seg\u00fan un estudio, el 44 % de los pacientes recurren a sus ahorros, el 27 % utilizan cr\u00e9ditos y el 26 % regresan a trabajar antes de estar listos.\n            <\/p>\n        <\/div>\n    <\/div>\n<\/section>\n\n\n<section class=\"section-padding bg-dark text-white\">\n    <div class=\"container\">\n        <h2 class=\"text-center fw-bold mb-5\">\u00bfSab\u00eda que?<\/h2>\n        <div class=\"row g-4\">\n                        <div class=\"col-md-6\">\n                <div class=\"d-flex mb-4\">\n                    <i class=\"fas fa-chart-line text-warning fa-2x me-3\"><\/i>\n                    <p class=\"mb-0\">Casi 1 de cada 2 personas se ver\u00e1 afectada por un c\u00e1ncer a lo largo de su vida, y 1 de cada 4 fallecer\u00e1 a causa de \u00e9l.<\/p>\n                <\/div>\n            <\/div>\n                        <div class=\"col-md-6\">\n                <div class=\"d-flex mb-4\">\n                    <i class=\"fas fa-chart-line text-warning fa-2x me-3\"><\/i>\n                    <p class=\"mb-0\">En Canad\u00e1, se estima aproximadamente 0,48 diagn\u00f3sticos por minuto en 2025.<\/p>\n                <\/div>\n            <\/div>\n                        <div class=\"col-md-6\">\n                <div class=\"d-flex mb-4\">\n                    <i class=\"fas fa-chart-line text-warning fa-2x me-3\"><\/i>\n                    <p class=\"mb-0\">1 de cada 4 personas tiene una enfermedad card\u00edaca diagnosticada en Canad\u00e1.<\/p>\n                <\/div>\n            <\/div>\n                        <div class=\"col-md-6\">\n                <div class=\"d-flex mb-4\">\n                    <i class=\"fas fa-chart-line text-warning fa-2x me-3\"><\/i>\n                    <p class=\"mb-0\">El 90 % de los canadienses creen que un diagn\u00f3stico tendr\u00eda un impacto importante en sus finanzas.<\/p>\n                <\/div>\n            <\/div>\n                    <\/div>\n    <\/div>\n<\/section>\n\n\n<section class=\"section-padding bg-light\">\n    <div class=\"container\">\n        <h2 class=\"text-center fw-bold mb-5\">Preguntas m\u00e1s frecuentes (FAQ)<\/h2>\n        <div class=\"row justify-content-center\">\n            <div class=\"col-lg-8\">\n                <div class=\"accordion\" id=\"faqMG\">\n                                        <div class=\"accordion-item border-0 mb-3 shadow-sm rounded-4 overflow-hidden\">\n                        <h2 class=\"accordion-header\">\n                            <button class=\"accordion-button collapsed fw-bold\" type=\"button\" data-bs-toggle=\"collapse\"\n                                data-bs-target=\"#faq0\">\n                                \u00bfQu\u00e9 es exactamente el seguro de enfermedades graves?\n                            <\/button>\n                        <\/h2>\n                        <div id=\"faq0\" class=\"accordion-collapse collapse\" data-bs-parent=\"#faqMG\">\n                            <div class=\"accordion-body text-muted\">Paga una cantidad global libre de impuestos tras el diagn\u00f3stico de una enfermedad cubierta (c\u00e1ncer, ACV, ataque al coraz\u00f3n).<\/div>\n                        <\/div>\n                    <\/div>\n                                        <div class=\"accordion-item border-0 mb-3 shadow-sm rounded-4 overflow-hidden\">\n                        <h2 class=\"accordion-header\">\n                            <button class=\"accordion-button collapsed fw-bold\" type=\"button\" data-bs-toggle=\"collapse\"\n                                data-bs-target=\"#faq1\">\n                                \u00bfLa indemnizaci\u00f3n est\u00e1 sujeta a impuestos?\n                            <\/button>\n                        <\/h2>\n                        <div id=\"faq1\" class=\"accordion-collapse collapse\" data-bs-parent=\"#faqMG\">\n                            <div class=\"accordion-body text-muted\">No. El capital pagado generalmente est\u00e1 libre de impuestos, permitiendo un uso libre sin impacto fiscal.<\/div>\n                        <\/div>\n                    <\/div>\n                                        <div class=\"accordion-item border-0 mb-3 shadow-sm rounded-4 overflow-hidden\">\n                        <h2 class=\"accordion-header\">\n                            <button class=\"accordion-button collapsed fw-bold\" type=\"button\" data-bs-toggle=\"collapse\"\n                                data-bs-target=\"#faq2\">\n                                \u00bfCu\u00e1l es la diferencia con el seguro de invalidez?\n                            <\/button>\n                        <\/h2>\n                        <div id=\"faq2\" class=\"accordion-collapse collapse\" data-bs-parent=\"#faqMG\">\n                            <div class=\"accordion-body text-muted\">El seguro de enfermedades graves paga una cantidad \u00fanica tras el diagn\u00f3stico, mientras que la invalidez reemplaza un ingreso mensual. Ambos son complementarios.<\/div>\n                        <\/div>\n                    <\/div>\n                                    <\/div>\n            <\/div>\n        <\/div>\n    <\/div>\n<\/section>\n\n\n<div class=\"container py-4 border-top\">\n    <small class=\"text-muted\">\n        <strong>Fuentes verificadas:<\/strong>\n        <ul class=\"list-inline mt-2\">\n                        <li class=\"list-inline-item\">\u2022 Statistics Canada (Estad\u00edsticas de Canad\u00e1)<\/li>\n                        <li class=\"list-inline-item\">\u2022 Sociedad Canadiense del C\u00e1ncer<\/li>\n                        <li class=\"list-inline-item\">\u2022 Autoridad de los Mercados Financieros (AMF)<\/li>\n                    <\/ul>\n    <\/small>\n<\/div>\n\n<footer class=\"footer-premium\">\r\n    <div class=\"container\">\r\n        <div class=\"row g-4\">\r\n\r\n            \r\n            <div class=\"col-lg-4 col-md-6 mb-4 mb-lg-0\">\r\n                <a href=\"https:\/\/vipgpi.net\/es\/home\" class=\"d-inline-block mb-4\">\r\n                    <img src=\"https:\/\/vipgpi.net\/assets\/img\/footer\/VIP_Logo_Gold_Gradient10.png\" alt=\"VIP GPI\"\r\n                        style=\"height: 90px;\">\r\n                <\/a>\r\n                <p class=\"pe-lg-5 mb-4\">\r\n                    Su prosperidad, nuestra prioridad\r\n                <\/p>\r\n\r\n                <div class=\"d-flex gap-3\">\r\n                    \r\n                                    <\/div>\r\n            <\/div>\r\n\r\n            \r\n            <div class=\"col-lg-2 col-md-6 mb-4 mb-lg-0\">\r\n                <h5 class=\"footer-title\">Navegaci\u00f3n<\/h5>\r\n                <ul class=\"footer-links\">\r\n                    <li><a href=\"https:\/\/vipgpi.net\/about\"><i class=\"fas fa-chevron-right\"><\/i> Acerca de<\/a>\r\n                    <\/li>\r\n                    <li><a href=\"https:\/\/vipgpi.net\/blog\"><i class=\"fas fa-chevron-right\"><\/i> Blog y Noticias<\/a>\r\n                    <\/li>\r\n                    <li><a href=\"https:\/\/vipgpi.net\/contact\"><i class=\"fas fa-chevron-right\"><\/i>\r\n                            Contacto<\/a><\/li>\r\n                    <li><a href=\"https:\/\/vipgpi.net\/login\"><i class=\"fas fa-lock\"><\/i> Acceso Asesor<\/a>\r\n                    <\/li>\r\n                <\/ul>\r\n            <\/div>\r\n\r\n            \r\n            <div class=\"col-lg-3 col-md-6 mb-4 mb-lg-0\">\r\n                <h5 c