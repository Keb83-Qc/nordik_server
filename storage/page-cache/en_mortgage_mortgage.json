          <\/a>\n                        <\/li>\n\n                    \n                    \n                \n            <\/ul>\n        <\/div>\n    <\/div>\n<\/nav>\n\n    \n    \n<section class=\"section-padding bg-white\">\n    <div class=\"container\">\n        <div class=\"row align-items-center\">\n            <div class=\"col-lg-6 mb-4 mb-lg-0\">\n                <h2 class=\"fw-bold mb-4\" style=\"color: var(--primary-color);\">What is a Mortgage Loan?<\/h2>\n                <div style=\"width: 60px; height: 3px; background: var(--secondary-color); margin-bottom: 20px;\"><\/div>\n                <div class=\"text-dark text-justify mb-4\" style=\"line-height: 1.8;\">\n                    <p>A mortgage loan is granted by a financial institution for the purchase of real estate. It is secured by a mortgage on the purchased property.<\/p>\n                <\/div>\n                <div class=\"d-flex gap-3 flex-wrap\">\n                    <a href=\"https:\/\/vipgpi.net\/rendez-vous\" class=\"btn btn-primary rounded-pill px-4 shadow-sm text-white fw-bold\">Get a Rate<\/a>\n                    <a href=\"https:\/\/vipgpi.net\/contact\" class=\"btn btn-outline-dark rounded-pill px-4 shadow-sm\">Contact Us<\/a>\n                <\/div>\n            <\/div>\n            <div class=\"col-lg-6\">\n                <img src=\"https:\/\/vipgpi.net\/assets\/img\/pretHypothecaire\/quest-ce-quun-pret-hypothecaire.jpg\" alt=\"Pr\u00eat hypoth\u00e9caire\" class=\"section-img rounded shadow hover-lift w-100 object-fit-cover\">\n            <\/div>\n        <\/div>\n    <\/div>\n<\/section>\n\n<section class=\"section-padding bg-light\">\n    <div class=\"container\">\n        <div class=\"text-center mb-5\">\n            <h2 class=\"fw-bold\" style=\"color:var(--primary-color);\">Important Aspects of a Mortgage Loan<\/h2>\n            <div style=\"width: 60px; height: 3px; background: var(--secondary-color); margin: 15px auto;\"><\/div>\n        <\/div>\n        <div class=\"row g-4 justify-content-center\">\n                                    <div class=\"col-md-6 col-lg-4\">\n                <div class=\"card h-100 border-0 shadow-sm p-4 text-center hover-lift\">\n                    <div class=\"mb-3\"><img src=\"https:\/\/vipgpi.net\/assets\/img\/pretHypothecaire\/loan_1999308.png\" width=\"64\" alt=\"Icone\"><\/div>\n                    <h5 class=\"fw-bold mb-3 text-dark\">Mortgage Guarantee<\/h5>\n                    <p class=\"text-muted small mb-0\">The property serves as collateral in case of non-payment.<\/p>\n                <\/div>\n            <\/div>\n                        <div class=\"col-md-6 col-lg-4\">\n                <div class=\"card h-100 border-0 shadow-sm p-4 text-center hover-lift\">\n                    <div class=\"mb-3\"><img src=\"https:\/\/vipgpi.net\/assets\/img\/pretHypothecaire\/tax_10165334.png\" width=\"64\" alt=\"Icone\"><\/div>\n                    <h5 class=\"fw-bold mb-3 text-dark\">Rate &amp; Repayment<\/h5>\n                    <p class=\"text-muted small mb-0\">Fixed or variable rates, progressive repayment of principal and interest.<\/p>\n                <\/div>\n            <\/div>\n                        <div class=\"col-md-6 col-lg-4\">\n                <div class=\"card h-100 border-0 shadow-sm p-4 text-center hover-lift\">\n                    <div class=\"mb-3\"><img src=\"https:\/\/vipgpi.net\/assets\/img\/pretHypothecaire\/budget_11732641.png\" width=\"64\" alt=\"Icone\"><\/div>\n                    <h5 class=\"fw-bold mb-3 text-dark\">Down Payment<\/h5>\n                    <p class=\"text-muted small mb-0\">Percentage of the purchase price paid by the borrower.<\/p>\n                <\/div>\n            <\/div>\n                        <div class=\"col-md-6 col-lg-4\">\n                <div class=\"card h-100 border-0 shadow-sm p-4 text-center hover-lift\">\n                    <div class=\"mb-3\"><img src=\"https:\/\/vipgpi.net\/assets\/img\/pretHypothecaire\/loan_3529249.png\" width=\"64\" alt=\"Icone\"><\/div>\n                    <h5 class=\"fw-bold mb-3 text-dark\">Loan Term<\/h5>\n                    <p class=\"text-muted small mb-0\">Amortization period, often 25 years.<\/p>\n                <\/div>\n            <\/div>\n                        <div class=\"col-md-6 col-lg-4\">\n                <div class=\"card h-100 border-0 shadow-sm p-4 text-center hover-lift\">\n                    <div class=\"mb-3\"><img src=\"https:\/\/vipgpi.net\/assets\/img\/pretHypothecaire\/electricity-bill_8564295.png\" width=\"64\" alt=\"Icone\"><\/div>\n                    <h5 class=\"fw-bold mb-3 text-dark\">Fees and Charges<\/h5>\n                    <p class=\"text-muted small mb-0\">Closing costs, appraisal, mortgage insurance, etc.<\/p>\n                <\/div>\n            <\/div>\n                        <div class=\"col-md-6 col-lg-4\">\n                <div class=\"card h-100 border-0 shadow-sm p-4 text-center hover-lift\">\n                    <div class=\"mb-3\"><img src=\"https:\/\/vipgpi.net\/assets\/img\/pretHypothecaire\/loan_1936178.png\" width=\"64\" alt=\"Icone\"><\/div>\n                    <h5 class=\"fw-bold mb-3 text-dark\">Amortization<\/h5>\n                    <p class=\"text-muted small mb-0\">Progressive accumulation of equity (net value) in the home.<\/p>\n                <\/div>\n            <\/div>\n                    <\/div>\n    <\/div>\n<\/section>\n\n<section class=\"section-padding bg-white\">\n    <div class=\"container\">\n        <div class=\"row align-items-center\">\n            <div class=\"col-lg-5 mb-4 mb-lg-0 text-center\">\n                <img src=\"https:\/\/vipgpi.net\/assets\/img\/pretHypothecaire\/AdobeStock_536174812.png\" alt=\"Calcul pr\u00eat\" class=\"img-fluid\" style=\"max-height: 400px;\">\n            <\/div>\n            <div class=\"col-lg-7\">\n                <div class=\"d-flex mb-4\">\n                    <div class=\"flex-shrink-0 me-3\"><i class=\"fas fa-info-circle fa-2x text-warning\